{
    "name": "dorpmaster/dbal-amphp-postgres",
    "description": "PostgreSQL-only Doctrine DBAL driver backed by an AMPHP transport.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "doctrine",
        "dbal",
        "postgres",
        "amphp",
        "async"
    ],
    "authors": [
        {
            "name": "Roman A. Shvetsov",
            "email": "tcp6000@gmail.com"
        }
    ],
    "homepage": "https://github.com/dorpmaster/dbal-amphp-postgres",
    "support": {
        "issues": "https://github.com/dorpmaster/dbal-amphp-postgres/issues",
        "source": "https://github.com/dorpmaster/dbal-amphp-postgres"
    },
    "require": {
        "php": "^8.5",
        "ext-ctype": "*",
        "ext-dom": "*",
        "ext-filter": "*",
        "ext-json": "*",
        "ext-libxml": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-tokenizer": "*",
        "ext-xml": "*",
        "ext-xmlwriter": "*",
        "amphp/amp": "^3.0",
        "amphp/postgres": "^2.0",
        "doctrine/dbal": "^4.4",
        "revolt/event-loop": "^1.0"
    },
    "require-dev": {
        "doctrine/orm": "^3.0",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0",
        "phpunit/phpunit": "^12.0",
        "symfony/cache": "^7.3",
        "symfony/var-exporter": "^7.3"
    },
    "autoload": {
        "psr-4": {
            "Dorpmaster\\DbalAmpPostgres\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dorpmaster\\DbalAmpPostgres\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
